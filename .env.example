# Copy to .env (gitignored) and fill in. Never commit real secrets.

# --- NCBI E-utilities (PubMed) ---
# Free key: https://www.ncbi.nlm.nih.gov/account/  -> Settings -> API Key Management
# Without a key you are limited to ~3 requests/sec; with one, ~10/sec.
NCBI_API_KEY=
# Courtesy identifiers NCBI asks callers to send.
NCBI_TOOL=literature-digest
NCBI_EMAIL=you@example.com

# --- Anthropic (Phase 2+; not used in Phase 1) ---
ANTHROPIC_API_KEY=

# --- Email delivery (Phase 3) ---
# Gmail relay -> any inbox. SMTP_PASSWORD must be a Gmail APP PASSWORD (16 chars,
# requires 2-Step Verification on the account), NOT your normal password:
#   https://myaccount.google.com/apppasswords
# DIGEST_FROM must match the relaying account (SMTP_USER) or the mail will fail
# SPF/DKIM and likely be quarantined. DIGEST_TO may be a comma-separated list.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=
DIGEST_FROM=you@gmail.com
DIGEST_TO=recipient@example.com

# --- Slack (optional, additional channel) ---
# Incoming Webhook URL for the channel to post the daily digest to. When set, the
# --send run also posts to Slack (email stays the system of record). Create one at
# https://api.slack.com/apps -> your app -> Incoming Webhooks -> Add to a channel.
# Leave blank to disable Slack.
SLACK_WEBHOOK_URL=
